#!/usr/bin/env python3
"""journal — daily diary saved locally as markdown.

By default, opens a clean writing UI window (via plan-ui). Terminal-only
subcommands are still available for quick listing and viewing.
"""

import os
import sys
from datetime import date, timedelta
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
JOURNAL_DIR = SCRIPT_DIR / "journal_entries"
PLAN_UI = SCRIPT_DIR / "plan-ui"
JOURNAL_DIR.mkdir(exist_ok=True)

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
CYAN = "\033[36m"


def today_str():
    return date.today().isoformat()


def entry_path(d=None):
    return JOURNAL_DIR / f"{d or today_str()}.md"


def open_ui(date_arg=None):
    """Launch the journal UI via plan-ui. Exec so Ctrl+C in this terminal
    cleanly stops the server once you're done writing."""
    args = [str(PLAN_UI), "journal"]
    if date_arg:
        args.append(date_arg)
    os.execvp(str(PLAN_UI), args)


def cmd_show(args):
    if not args:
        sys.exit("Usage: journal show <YYYY-MM-DD>")
    p = entry_path(args[0])
    if not p.exists():
        print(f"\n  {DIM}No entry for {args[0]}.{RESET}\n")
        return
    print()
    print(p.read_text())
    print()


def cmd_list(args):
    files = sorted(JOURNAL_DIR.glob("*.md"), reverse=True)
    if not files:
        print(f"\n  {DIM}No entries yet. Start one:  journal{RESET}\n")
        return
    print()
    print(f"  {BOLD}Journal entries{RESET}")
    print()
    for f in files:
        lines = f.read_text().strip().splitlines()
        preview = ""
        for line in lines:
            s = line.strip()
            # Skip blank lines, headings, and italic-wrapped prompts.
            if not s or s.startswith("#") or s.startswith("*"):
                continue
            preview = s[:70] + ("…" if len(s) > 70 else "")
            break
        preview_colored = f"  {DIM}{preview}{RESET}" if preview else f"  {DIM}(empty){RESET}"
        print(f"  {CYAN}{f.stem}{RESET}{preview_colored}")
    print()


def cmd_help(args=None):
    print(f"""
{BOLD}journal{RESET} — daily diary in markdown

{BOLD}Usage:{RESET}
  journal                    Open today's entry in the writing UI
  journal yesterday          Open yesterday's entry in the UI
  journal <YYYY-MM-DD>       Open a specific date in the UI

{BOLD}Terminal-only:{RESET}
  journal show <date>        Print a past entry to the terminal
  journal list               List all entries with previews
  journal help               Show this help

{BOLD}UI shortcuts (once the window is open):{RESET}
  {DIM}‹ / ›            Previous / next day{RESET}
  {DIM}⌘P or Ctrl+P     Toggle Write ↔ Preview{RESET}
  {DIM}⌘S or Ctrl+S     Force save (auto-save is on){RESET}

{BOLD}Data:{RESET}
  {DIM}Each day saved as Markdown under  {JOURNAL_DIR}  (gitignored){RESET}
""")


HELP_ALIASES = {"-h", "--h", "-help", "--help", "-?", "/?"}


def is_date(s):
    return len(s) == 10 and s[4] == "-" and s[7] == "-" and s[:4].isdigit()


def main():
    args = sys.argv[1:]
    if not args:
        open_ui()
        return

    first = args[0]

    if first in HELP_ALIASES or first.lower() in ("help", "h"):
        cmd_help()
        return
    if first.lower() == "yesterday":
        yd = (date.today() - timedelta(days=1)).isoformat()
        open_ui(yd)
        return
    if first == "show":
        cmd_show(args[1:])
        return
    if first == "list":
        cmd_list(args[1:])
        return
    if is_date(first):
        open_ui(first)
        return

    print(f"Unknown command: {first}\n")
    cmd_help()
    sys.exit(1)


if __name__ == "__main__":
    main()
