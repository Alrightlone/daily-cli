#!/usr/bin/env python3
"""plan-ui — launch the plan web interface in a native-feeling Chrome window."""

import http.server
import json
import socket
import socketserver
import subprocess
import sys
import threading
from datetime import date
from pathlib import Path
from urllib.parse import parse_qs, urlparse

SCRIPT_DIR = Path(__file__).resolve().parent
PLANS_DIR = SCRIPT_DIR / "plans"
JOURNAL_DIR = SCRIPT_DIR / "journal_entries"
UI_DIR = SCRIPT_DIR / "ui"
PLANS_DIR.mkdir(exist_ok=True)
JOURNAL_DIR.mkdir(exist_ok=True)


def today_str():
    return date.today().isoformat()


def plan_path(d=None):
    return PLANS_DIR / f"{d or today_str()}.json"


def load_plan(d=None):
    p = plan_path(d)
    if p.exists():
        return json.loads(p.read_text())
    return {"date": d or today_str(), "tasks": []}


def save_plan(plan):
    plan_path(plan["date"]).write_text(
        json.dumps(plan, indent=2, ensure_ascii=False) + "\n"
    )


def next_id(plan):
    return max((t["id"] for t in plan["tasks"]), default=0) + 1


def journal_path(d=None):
    return JOURNAL_DIR / f"{d or today_str()}.md"


def load_journal(d=None):
    p = journal_path(d)
    if p.exists():
        return p.read_text(encoding="utf-8")
    return ""


def save_journal(d, content):
    journal_path(d).write_text(content, encoding="utf-8")


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *args):
        pass

    def _json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _html(self, text):
        body = text.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _body(self):
        n = int(self.headers.get("Content-Length", 0))
        if not n:
            return {}
        return json.loads(self.rfile.read(n).decode("utf-8"))

    def _serve_bg(self, name):
        # guard against path traversal
        if "/" in name or ".." in name or "\\" in name:
            return self.send_error(400)
        f = SCRIPT_DIR / "background" / name
        if not f.exists() or not f.is_file():
            return self.send_error(404)
        mime = {
            ".png": "image/png", ".jpg": "image/jpeg", ".jpeg": "image/jpeg",
            ".gif": "image/gif", ".webp": "image/webp",
        }.get(f.suffix.lower(), "application/octet-stream")
        data = f.read_bytes()
        self.send_response(200)
        self.send_header("Content-Type", mime)
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "public, max-age=3600")
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        u = urlparse(self.path)
        if u.path == "/":
            self._html((UI_DIR / "index.html").read_text(encoding="utf-8"))
        elif u.path == "/mini":
            self._html((UI_DIR / "mini.html").read_text(encoding="utf-8"))
        elif u.path == "/journal":
            self._html((UI_DIR / "journal.html").read_text(encoding="utf-8"))
        elif u.path == "/api/journal":
            d = parse_qs(u.query).get("date", [None])[0]
            self._json({"date": d or today_str(), "content": load_journal(d)})
        elif u.path == "/api/journal/dates":
            dates = sorted([f.stem for f in JOURNAL_DIR.glob("*.md")], reverse=True)
            self._json({"dates": dates})
        elif u.path.startswith("/bg/"):
            self._serve_bg(u.path[4:])
        elif u.path == "/api/backgrounds":
            bg_dir = SCRIPT_DIR / "background"
            exts = (".png", ".jpg", ".jpeg", ".gif", ".webp")
            images = sorted([
                f.name for f in bg_dir.glob("*")
                if f.is_file() and f.suffix.lower() in exts
            ]) if bg_dir.exists() else []
            self._json({"images": images})
        elif u.path == "/api/plan":
            d = parse_qs(u.query).get("date", [None])[0]
            self._json(load_plan(d))
        elif u.path == "/api/dates":
            dates = [f.stem for f in sorted(PLANS_DIR.glob("*.json"), reverse=True)]
            self._json({"dates": dates})
        else:
            self.send_error(404)

    def do_PUT(self):
        u = urlparse(self.path)
        if u.path == "/api/journal":
            body = self._body()
            d = (body.get("date") or today_str()).strip()
            content = body.get("content", "")
            if not isinstance(content, str):
                return self.send_error(400)
            # guard: YYYY-MM-DD only
            if len(d) != 10 or d[4] != "-" or d[7] != "-":
                return self.send_error(400)
            save_journal(d, content)
            return self._json({"ok": True, "date": d})
        self.send_error(404)

    def do_POST(self):
        if urlparse(self.path).path == "/api/tasks":
            body = self._body()
            text = (body.get("text") or "").strip()
            if not text:
                return self.send_error(400)
            plan = load_plan()
            plan["tasks"].append({
                "id": next_id(plan),
                "text": text,
                "status": "pending",
                "note": None,
            })
            save_plan(plan)
            return self._json(plan)
        self.send_error(404)

    def do_PATCH(self):
        parts = urlparse(self.path).path.strip("/").split("/")
        if len(parts) == 3 and parts[0] == "api" and parts[1] == "tasks":
            try:
                tid = int(parts[2])
            except ValueError:
                return self.send_error(400)
            body = self._body()
            plan = load_plan()
            t = next((t for t in plan["tasks"] if t["id"] == tid), None)
            if not t:
                return self.send_error(404)
            if "text" in body:
                new_text = (body["text"] or "").strip()
                if new_text:
                    t["text"] = new_text
            if "status" in body:
                t["status"] = body["status"]
                if body["status"] not in ("half", "skip"):
                    t["note"] = None
            if "note" in body:
                t["note"] = (body["note"] or "").strip() or None
            save_plan(plan)
            return self._json(plan)
        self.send_error(404)

    def do_DELETE(self):
        u = urlparse(self.path)
        parts = u.path.strip("/").split("/")
        if len(parts) == 3 and parts[0] == "api" and parts[1] == "tasks":
            try:
                tid = int(parts[2])
            except ValueError:
                return self.send_error(400)
            plan = load_plan()
            plan["tasks"] = [t for t in plan["tasks"] if t["id"] != tid]
            save_plan(plan)
            return self._json(plan)
        if u.path == "/api/plan":
            plan = load_plan()
            plan["tasks"] = []
            save_plan(plan)
            return self._json(plan)
        self.send_error(404)


def free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


def open_in_chrome_app(url, size=(720, 800), position=None, profile="full"):
    """Open as a standalone Chrome window (no tabs, no URL bar).

    Each profile gets its own --user-data-dir so window state (size, position)
    is remembered independently for the full vs. mini windows.
    """
    chrome = "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    w, h = size
    profile_dir = Path.home() / ".cache" / "daily-cli" / f"chrome-{profile}"
    profile_dir.mkdir(parents=True, exist_ok=True)
    args = [
        chrome,
        f"--user-data-dir={profile_dir}",
        "--no-first-run",
        "--no-default-browser-check",
        f"--app={url}",
        f"--window-size={w},{h}",
    ]
    if position is not None:
        x, y = position
        args.append(f"--window-position={x},{y}")
    if Path(chrome).exists():
        subprocess.Popen(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        subprocess.Popen(["open", url])


class ReusableServer(socketserver.TCPServer):
    allow_reuse_address = True


def launch(port, mode, date_arg=None):
    base = f"http://127.0.0.1:{port}"
    mini_size = (300, 460)
    mini_pos = (1580, 80)
    full_size = (720, 800)
    journal_size = (760, 820)
    if mode == "mini":
        open_in_chrome_app(f"{base}/mini", size=mini_size, position=mini_pos, profile="mini")
    elif mode == "both":
        open_in_chrome_app(f"{base}/", size=full_size, profile="full")
        threading.Timer(0.4, lambda: open_in_chrome_app(
            f"{base}/mini", size=mini_size, position=mini_pos, profile="mini"
        )).start()
    elif mode == "journal":
        url = f"{base}/journal"
        if date_arg:
            url += f"?date={date_arg}"
        open_in_chrome_app(url, size=journal_size, profile="journal")
    else:
        open_in_chrome_app(f"{base}/", size=full_size, profile="full")


def main():
    args = sys.argv[1:]
    mode = "full"
    date_arg = None
    if args:
        a = args[0].lstrip("-")
        if a in ("mini", "m"):
            mode = "mini"
        elif a in ("both", "b", "all"):
            mode = "both"
        elif a in ("journal", "j"):
            mode = "journal"
            # optional second arg: YYYY-MM-DD
            if len(args) > 1:
                d = args[1]
                if len(d) == 10 and d[4] == "-" and d[7] == "-":
                    date_arg = d
        elif a in ("help", "h"):
            print("\nUsage:  plan-ui [mini | both | journal]\n")
            print("  plan-ui          full desktop-style window")
            print("  plan-ui mini     compact widget for desktop corner")
            print("  plan-ui both     both windows on one server (live sync)")
            print("  plan-ui journal [YYYY-MM-DD]   journal editor window\n")
            return

    port = free_port()
    print(f"\n  plan-ui ({mode})  →  http://127.0.0.1:{port}")
    print(f"  Ctrl+C to stop\n")
    threading.Timer(0.3, lambda: launch(port, mode, date_arg)).start()
    with ReusableServer(("127.0.0.1", port), Handler) as httpd:
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            print("\n  Stopped.\n")


if __name__ == "__main__":
    main()
