#!/usr/bin/env python3
"""plan-ui — launch the plan web interface in a native-feeling Chrome window."""

import http.server
import json
import socket
import socketserver
import subprocess
import sys
import threading
from datetime import date
from pathlib import Path
from urllib.parse import parse_qs, urlparse

SCRIPT_DIR = Path(__file__).resolve().parent
PLANS_DIR = SCRIPT_DIR / "plans"
UI_DIR = SCRIPT_DIR / "ui"
PLANS_DIR.mkdir(exist_ok=True)


def today_str():
    return date.today().isoformat()


def plan_path(d=None):
    return PLANS_DIR / f"{d or today_str()}.json"


def load_plan(d=None):
    p = plan_path(d)
    if p.exists():
        return json.loads(p.read_text())
    return {"date": d or today_str(), "tasks": []}


def save_plan(plan):
    plan_path(plan["date"]).write_text(
        json.dumps(plan, indent=2, ensure_ascii=False) + "\n"
    )


def next_id(plan):
    return max((t["id"] for t in plan["tasks"]), default=0) + 1


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *args):
        pass

    def _json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _html(self, text):
        body = text.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _body(self):
        n = int(self.headers.get("Content-Length", 0))
        if not n:
            return {}
        return json.loads(self.rfile.read(n).decode("utf-8"))

    def do_GET(self):
        u = urlparse(self.path)
        if u.path == "/":
            self._html((UI_DIR / "index.html").read_text(encoding="utf-8"))
        elif u.path == "/mini":
            self._html((UI_DIR / "mini.html").read_text(encoding="utf-8"))
        elif u.path == "/api/plan":
            d = parse_qs(u.query).get("date", [None])[0]
            self._json(load_plan(d))
        elif u.path == "/api/dates":
            dates = [f.stem for f in sorted(PLANS_DIR.glob("*.json"), reverse=True)]
            self._json({"dates": dates})
        else:
            self.send_error(404)

    def do_POST(self):
        if urlparse(self.path).path == "/api/tasks":
            body = self._body()
            text = (body.get("text") or "").strip()
            if not text:
                return self.send_error(400)
            plan = load_plan()
            plan["tasks"].append({
                "id": next_id(plan),
                "text": text,
                "status": "pending",
                "note": None,
            })
            save_plan(plan)
            return self._json(plan)
        self.send_error(404)

    def do_PATCH(self):
        parts = urlparse(self.path).path.strip("/").split("/")
        if len(parts) == 3 and parts[0] == "api" and parts[1] == "tasks":
            try:
                tid = int(parts[2])
            except ValueError:
                return self.send_error(400)
            body = self._body()
            plan = load_plan()
            t = next((t for t in plan["tasks"] if t["id"] == tid), None)
            if not t:
                return self.send_error(404)
            if "text" in body:
                new_text = (body["text"] or "").strip()
                if new_text:
                    t["text"] = new_text
            if "status" in body:
                t["status"] = body["status"]
                if body["status"] not in ("half", "skip"):
                    t["note"] = None
            if "note" in body:
                t["note"] = (body["note"] or "").strip() or None
            save_plan(plan)
            return self._json(plan)
        self.send_error(404)

    def do_DELETE(self):
        u = urlparse(self.path)
        parts = u.path.strip("/").split("/")
        if len(parts) == 3 and parts[0] == "api" and parts[1] == "tasks":
            try:
                tid = int(parts[2])
            except ValueError:
                return self.send_error(400)
            plan = load_plan()
            plan["tasks"] = [t for t in plan["tasks"] if t["id"] != tid]
            save_plan(plan)
            return self._json(plan)
        if u.path == "/api/plan":
            plan = load_plan()
            plan["tasks"] = []
            save_plan(plan)
            return self._json(plan)
        self.send_error(404)


def free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(("127.0.0.1", 0))
        return s.getsockname()[1]


def open_in_chrome_app(url, size=(720, 800), position=None):
    """Open as a standalone Chrome window (no tabs, no URL bar)."""
    chrome = "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    w, h = size
    args = [chrome, f"--app={url}", f"--window-size={w},{h}"]
    if position is not None:
        x, y = position
        args.append(f"--window-position={x},{y}")
    if Path(chrome).exists():
        subprocess.Popen(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        subprocess.Popen(["open", url])


class ReusableServer(socketserver.TCPServer):
    allow_reuse_address = True


def launch(port, mode):
    base = f"http://127.0.0.1:{port}"
    if mode == "mini":
        open_in_chrome_app(f"{base}/mini", size=(300, 460), position=(1580, 80))
    elif mode == "both":
        open_in_chrome_app(f"{base}/", size=(720, 800))
        time_delay = threading.Timer(
            0.4,
            lambda: open_in_chrome_app(f"{base}/mini", size=(300, 460), position=(1580, 80)),
        )
        time_delay.start()
    else:
        open_in_chrome_app(f"{base}/", size=(720, 800))


def main():
    args = sys.argv[1:]
    mode = "full"
    if args:
        a = args[0].lstrip("-")
        if a in ("mini", "m"):
            mode = "mini"
        elif a in ("both", "b", "all"):
            mode = "both"
        elif a in ("help", "h"):
            print("\nUsage:  plan-ui [mini | both]\n")
            print("  plan-ui          full desktop-style window")
            print("  plan-ui mini     compact widget for desktop corner")
            print("  plan-ui both     both windows on one server (live sync)\n")
            return

    port = free_port()
    print(f"\n  plan-ui ({mode})  →  http://127.0.0.1:{port}")
    print(f"  Ctrl+C to stop\n")
    threading.Timer(0.3, lambda: launch(port, mode)).start()
    with ReusableServer(("127.0.0.1", port), Handler) as httpd:
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            print("\n  Stopped.\n")


if __name__ == "__main__":
    main()
