#!/usr/bin/env python3
"""plan — daily task planner saved locally."""

import json
import os
import subprocess
import sys
from datetime import date, timedelta
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
PLANS_DIR = SCRIPT_DIR / "plans"
RECUR_FILE = SCRIPT_DIR / "recurring.json"
PLANS_DIR.mkdir(exist_ok=True)

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
CYAN = "\033[36m"

STATUS = {
    "pending": ("☐", DIM),
    "done":    ("✓", GREEN),
    "half":    ("◐", YELLOW),
    "skip":    ("✗", RED),
}


def today_str():
    return date.today().isoformat()


def plan_path(d=None):
    return PLANS_DIR / f"{d or today_str()}.json"


def load_plan(d=None):
    p = plan_path(d)
    if p.exists():
        return json.loads(p.read_text())
    return {"date": d or today_str(), "tasks": []}


def save_plan(plan):
    plan_path(plan["date"]).write_text(
        json.dumps(plan, indent=2, ensure_ascii=False) + "\n"
    )


def next_id(plan):
    return max((t["id"] for t in plan["tasks"]), default=0) + 1


def get_task(plan, tid):
    return next((t for t in plan["tasks"] if t["id"] == tid), None)


# ── Recurring task rules ─────────────────────────────────────
DAY_NAMES = {"mon": 0, "tue": 1, "wed": 2, "thu": 3, "fri": 4, "sat": 5, "sun": 6}


def valid_schedule(s: str) -> bool:
    s = s.lower().strip()
    if s in ("daily", "weekday", "weekend"):
        return True
    parts = [p.strip() for p in s.split(",") if p.strip()]
    return bool(parts) and all(p in DAY_NAMES for p in parts)


def matches_schedule(schedule: str, d: date) -> bool:
    s = schedule.lower().strip()
    dow = d.weekday()
    if s == "daily":
        return True
    if s == "weekday":
        return dow < 5
    if s == "weekend":
        return dow >= 5
    for part in s.split(","):
        part = part.strip()
        if part in DAY_NAMES and DAY_NAMES[part] == dow:
            return True
    return False


def load_recurring():
    if RECUR_FILE.exists():
        return json.loads(RECUR_FILE.read_text())
    return {"next_id": 1, "rules": []}


def save_recurring(data):
    RECUR_FILE.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n")


# ── Carry-over + recurring population for a fresh day ────────
def initialize_today_if_new():
    """On the first `plan` of a new day, populate today from yesterday's pending
    tasks and any recurring rules that match. Idempotent after the file exists."""
    p = plan_path()
    if p.exists():
        return

    plan = {"date": today_str(), "tasks": []}

    # 1. Carry over yesterday's pending tasks
    yesterday = (date.today() - timedelta(days=1)).isoformat()
    y_path = plan_path(yesterday)
    if y_path.exists():
        y_plan = json.loads(y_path.read_text())
        for t in y_plan["tasks"]:
            if t["status"] == "pending":
                plan["tasks"].append({
                    "id": next_id(plan),
                    "text": t["text"],
                    "status": "pending",
                    "note": None,
                    "carried_from": yesterday,
                })

    # 2. Add matching recurring tasks (skip duplicates by text)
    existing_texts = {t["text"] for t in plan["tasks"]}
    rec = load_recurring()
    for rule in rec.get("rules", []):
        if matches_schedule(rule["schedule"], date.today()) and rule["text"] not in existing_texts:
            plan["tasks"].append({
                "id": next_id(plan),
                "text": rule["text"],
                "status": "pending",
                "note": None,
                "recurring": rule["schedule"],
            })

    if plan["tasks"]:
        save_plan(plan)


# ── Streak calculation ───────────────────────────────────────
def compute_streak() -> int:
    """Consecutive days ending today with at least 1 completed task.
    Today counts only if it already has a done task."""
    streak = 0
    today = date.today()

    def day_has_done(d):
        p = plan_path(d.isoformat())
        if not p.exists():
            return None  # no file at all
        data = json.loads(p.read_text())
        return any(t["status"] == "done" for t in data["tasks"])

    # Today: optional anchor
    if day_has_done(today):
        streak += 1

    # Walk back from yesterday
    d = today - timedelta(days=1)
    while True:
        state = day_has_done(d)
        if state is None or state is False:
            break
        streak += 1
        d -= timedelta(days=1)
    return streak


def show_plan(plan):
    tasks = plan["tasks"]
    d = plan["date"]
    is_today = (d == today_str())
    label = "Today" if is_today else ""
    header = f"{BOLD}{CYAN}📅 {d}{RESET}"
    if label:
        header += f"  {DIM}· {label}{RESET}"

    print()
    print(f"  {header}")
    print()

    if not tasks:
        print(f'  {DIM}No tasks yet.  Add one:  plan add "your task"{RESET}')
        print()
        return

    for t in tasks:
        icon, color = STATUS[t["status"]]
        text = t["text"]
        if t["status"] == "done":
            text = f"{DIM}{text}{RESET}"
        tags = []
        if t.get("carried_from"):
            tags.append(f"{CYAN}↪{RESET}")
        if t.get("recurring"):
            tags.append(f"{CYAN}↻{RESET}")
        tag_part = " " + "".join(tags) if tags else ""
        note = t.get("note")
        note_part = f"  {DIM}· {note}{RESET}" if note else ""
        print(f"  {DIM}{t['id']:>2}{RESET}  {color}{icon}{RESET}  {text}{tag_part}{note_part}")

    counts = {"done": 0, "half": 0, "skip": 0, "pending": 0}
    for t in tasks:
        counts[t["status"]] += 1
    total = len(tasks)
    parts = [f"{counts['done']}/{total} done"]
    if counts["half"]:
        parts.append(f"{counts['half']} half")
    if counts["skip"]:
        parts.append(f"{counts['skip']} skipped")
    if counts["pending"]:
        parts.append(f"{counts['pending']} pending")

    print()
    print(f"  {DIM}{'─' * 40}{RESET}")
    print(f"  {DIM}{' · '.join(parts)}{RESET}")

    streak = compute_streak()
    if streak > 0 and is_today:
        flame = "🔥" if streak >= 3 else "·"
        print(f"  {DIM}{flame} {streak}-day streak{RESET}")
    print()


def parse_id(args, cmd):
    if not args:
        sys.exit(f"Usage: plan {cmd} <id>")
    try:
        return int(args[0])
    except ValueError:
        sys.exit(f"Invalid id: {args[0]}")


def cmd_add(args):
    if not args:
        sys.exit('Usage: plan add "task description"')
    plan = load_plan()
    plan["tasks"].append({
        "id": next_id(plan),
        "text": " ".join(args),
        "status": "pending",
        "note": None,
    })
    save_plan(plan)
    show_plan(plan)


def cmd_set_status(args, cmd, status, need_note):
    tid = parse_id(args, cmd)
    plan = load_plan()
    t = get_task(plan, tid)
    if not t:
        sys.exit(f"Task {tid} not found")
    t["status"] = status
    if need_note:
        try:
            note = input(f"  {DIM}Reason:{RESET} ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            sys.exit(1)
        t["note"] = note or None
    else:
        t["note"] = None
    save_plan(plan)
    show_plan(plan)


def cmd_rm(args):
    tid = parse_id(args, "rm")
    plan = load_plan()
    plan["tasks"] = [t for t in plan["tasks"] if t["id"] != tid]
    save_plan(plan)
    show_plan(plan)


def cmd_edit(args):
    # `plan edit`           → open JSON in $EDITOR
    # `plan edit <id> text` → rewrite task <id>'s text
    if not args:
        ed = os.environ.get("EDITOR", "nano")
        subprocess.call([ed, str(plan_path())])
        return
    tid = parse_id(args, "edit")
    if len(args) < 2:
        sys.exit('Usage: plan edit <id> "new text"')
    plan = load_plan()
    t = get_task(plan, tid)
    if not t:
        sys.exit(f"Task {tid} not found")
    t["text"] = " ".join(args[1:])
    save_plan(plan)
    show_plan(plan)


def cmd_clear(args):
    plan = load_plan()
    if not plan["tasks"]:
        print(f"\n  {DIM}No tasks to clear.{RESET}\n")
        return
    try:
        ans = input(f"  {YELLOW}Clear all {len(plan['tasks'])} tasks? [y/N]:{RESET} ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return
    if ans == "y":
        plan["tasks"] = []
        save_plan(plan)
        show_plan(plan)
    else:
        print(f"  {DIM}Cancelled.{RESET}\n")


def cmd_show(args):
    if not args:
        sys.exit("Usage: plan show <YYYY-MM-DD>")
    show_plan(load_plan(args[0]))


def cmd_list(args):
    files = sorted(PLANS_DIR.glob("*.json"), reverse=True)
    if not files:
        print("\n  No saved plans yet.\n")
        return
    print()
    for f in files:
        plan = json.loads(f.read_text())
        n = len(plan["tasks"])
        done = sum(1 for t in plan["tasks"] if t["status"] == "done")
        print(f"  {CYAN}{f.stem}{RESET}  {DIM}·{RESET}  {done}/{n} done")
    print()


def cmd_recur(args):
    """Manage recurring task rules."""
    if not args or args[0] == "list":
        rec = load_recurring()
        if not rec["rules"]:
            print(f"\n  {DIM}No recurring rules. Add one:{RESET}")
            print(f'  {DIM}  plan recur add weekday "健身"{RESET}\n')
            return
        print()
        print(f"  {BOLD}Recurring rules{RESET}")
        print()
        for r in rec["rules"]:
            print(f"  {DIM}{r['id']:>2}{RESET}  {CYAN}{r['schedule']:<12}{RESET}  {r['text']}")
        print()
        print(f"  {DIM}Schedules: daily · weekday · weekend · mon,wed,fri (any combo){RESET}\n")
        return

    sub = args[0]
    if sub == "add":
        if len(args) < 3:
            sys.exit('Usage: plan recur add <schedule> "text"')
        schedule = args[1]
        if not valid_schedule(schedule):
            sys.exit("Invalid schedule. Use: daily | weekday | weekend | mon,wed,fri ...")
        text = " ".join(args[2:])
        rec = load_recurring()
        rec["rules"].append({
            "id": rec["next_id"],
            "text": text,
            "schedule": schedule.lower(),
        })
        rec["next_id"] += 1
        save_recurring(rec)
        cmd_recur(["list"])
        return

    if sub == "rm":
        if len(args) < 2:
            sys.exit("Usage: plan recur rm <id>")
        try:
            rid = int(args[1])
        except ValueError:
            sys.exit(f"Invalid id: {args[1]}")
        rec = load_recurring()
        before = len(rec["rules"])
        rec["rules"] = [r for r in rec["rules"] if r["id"] != rid]
        if len(rec["rules"]) == before:
            sys.exit(f"No recurring rule with id {rid}")
        save_recurring(rec)
        cmd_recur(["list"])
        return

    sys.exit(f"Unknown subcommand: {sub}\nTry: plan recur [list | add | rm]")


def cmd_week(args):
    """Show the last 7 days at a glance."""
    today = date.today()
    print()
    print(f"  {BOLD}Last 7 days{RESET}")
    print()
    for i in range(6, -1, -1):
        d = today - timedelta(days=i)
        p = plan_path(d.isoformat())
        day_name = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"][d.weekday()]
        date_str = d.strftime("%b %d")
        marker = f"  {DIM}← today{RESET}" if d == today else ""
        if p.exists():
            data = json.loads(p.read_text())
            n = len(data["tasks"])
            done = sum(1 for t in data["tasks"] if t["status"] == "done")
            half = sum(1 for t in data["tasks"] if t["status"] == "half")
            skip = sum(1 for t in data["tasks"] if t["status"] == "skip")
            pending = n - done - half - skip
            width = 20
            if n > 0:
                bar = (
                    f"{GREEN}{'█' * int(done / n * width)}{RESET}"
                    f"{YELLOW}{'█' * int(half / n * width)}{RESET}"
                    f"{RED}{'█' * int(skip / n * width)}{RESET}"
                    f"{DIM}{'░' * (width - int(done / n * width) - int(half / n * width) - int(skip / n * width))}{RESET}"
                )
            else:
                bar = f"{DIM}{'░' * width}{RESET}"
            summary = f"{done}/{n}"
            print(f"  {day_name} {date_str:>6}  {bar}  {DIM}{summary:>6}{RESET}{marker}")
        else:
            print(f"  {day_name} {date_str:>6}  {DIM}{'·' * 20}  {'—':>6}{RESET}{marker}")

    streak = compute_streak()
    print()
    if streak > 0:
        flame = "🔥" if streak >= 3 else "·"
        print(f"  {DIM}{flame} {streak}-day streak{RESET}")
    else:
        print(f"  {DIM}No active streak — finish one task today to start one.{RESET}")
    print()


