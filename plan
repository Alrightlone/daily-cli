HANDLERS = {
    "add":    cmd_add,
    "done":   lambda a: cmd_set_status(a, "done", "done", False),
    "half":   lambda a: cmd_set_status(a, "half", "half", True),
    "skip":   lambda a: cmd_set_status(a, "skip", "skip", True),
    "rm":     cmd_rm,
    "clear":  cmd_clear,
    "edit":   cmd_edit,
    "recur":  cmd_recur,
    "week":   cmd_week,
    "show":   cmd_show,
    "list":   cmd_list,
    "help":   cmd_help,
}

HELP_ALIASES = {"-h", "--h", "-help", "--help", "-?", "/?"}


def main():
    args = sys.argv[1:]
    # Populate today's plan with carry-over + recurring on first call each day
    initialize_today_if_new()

    if not args:
        show_plan(load_plan())
        return
    cmd, rest = args[0], args[1:]
    if cmd in HELP_ALIASES:
        cmd_help(rest)
        return
    h = HANDLERS.get(cmd)
    if not h:
        print(f"Unknown command: {cmd}\n")
        cmd_help([])
        sys.exit(1)
    h(rest)


if __name__ == "__main__":
    main()
